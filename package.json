{
  "name": "tashil-code-plugin",
  "version": "1.0.0",
  "private": true,
  "description": "Figma Dev Mode codegen plugin for Tashil UI components",
  "scripts": {
    "build": "npm run typecheck && build-figma-plugin --minify",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.ui.json && tsc -p tsconfig.tests.json && tsc -p tsconfig.plugin-tests.json",
    "watch": "npm run typecheck && build-figma-plugin --typecheck --watch"
  },
  "figma-plugin": {
    "id": "1654920127584180700",
    "name": "Tashil Code",
    "api": "1.0.0",
    "main": "src/main.ts",
    "ui": "src/ui.tsx",
    "capabilities": [
      "codegen"
    ],
    "enableProposedApi": false,
    "documentAccess": "dynamic-page",
    "editorType": [
      "figma",
      "dev"
    ],
    "menu": [
      {
        "name": "Connect component",
        "main": "src/main.ts",
        "ui": "src/ui.tsx"
      }
    ],
    "codegenLanguages": [
      {
        "label": "Tashil UI",
        "value": "tashil-ui"
      }
    ],
    "networkAccess": {
      "allowedDomains": [
        "none"
      ]
    }
  },
  "author": "danialshirali16 <danialshirali16@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@create-figma-plugin/build": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@figma/eslint-plugin-figma-plugins": "1.0.0",
    "@figma/plugin-typings": "1.130.0",
    "@testing-library/preact": "3.2.4",
    "eslint": "^9.39.4",
    "jsdom": "26.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@create-figma-plugin/ui": "^4.0.3",
    "@create-figma-plugin/utilities": "^4.0.3",
    "preact": "^10.29.4"
  }
}
